FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      topoSetDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //



#include "../input"   

// compute min and max x-coordinates of the vent based on vL
minX  #calc "0.5 - 0.5*$vL";
maxX  #calc "0.5 + 0.5*$vL";

actions
(
    {
        name    wallsLid_faces;
        type    faceSet;
        action  new;
        source  patchToFace;
        sourceInfo
        {
            patch wallsLid;
        }
    }
    {
        name    wallsLid_faces;
        type    faceSet;
        action  subset;
        source  boxToFace;
        sourceInfo
        {
            box ($minX 1.9 -1.1) ($maxX 2.1 0.1);
        }
    }
);

